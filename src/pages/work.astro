---
import Layout from "../layouts/Layout.astro";
import stack from "../data/stack.json";
import education from "../data/education.json";
import experience from "../data/experience.json";
import projects from "../data/featured-projects.json";

const navItems = [
    { label: "About", href: "#about" },
    { label: "Education", href: "#education" },
    { label: "Experience", href: "#experience" },
    { label: "Stack", href: "#stack" },
    { label: "Projects", href: "#projects" },
];
---

<Layout title="Work">

    <!-- Hero -->
    <section class="hero">
        <div class="hero-inner">
            <p class="hero-label">Software Developer</p>
            <h1 class="hero-name">Keegan Tournay</h1>
            <p class="hero-tagline">
                If it doesn't exist, I'll build it.<br>
                If it exists but isn't good enough, I'll build it <em>better</em>.
            </p>
            <div class="hero-actions">
                <a href="/resume.pdf" download class="btn-primary">Download Resume</a>
                <a href="mailto:contact@keegant.dev" class="btn-secondary">Get in Touch</a>
            </div>
        </div>
    </section>

    <!-- Section nav -->
    <nav class="section-nav" id="section-nav">
        <div class="section-nav-inner">
            {navItems.map(item => (
                    <a href={item.href} class="snav-link" data-section={item.href.slice(1)}>{item.label}</a>
            ))}
        </div>
    </nav>

    <div class="work-body">

        <!-- About -->
        <section class="work-section" id="about">
            <div class="section-label">About</div>
            <div class="about-grid">
                <div class="about-text">
                    <p>I'm a 23-year-old software developer from Ontario, Canada, finishing my Bachelor of Technology in
                        Software Engineering at McMaster University. I've been building things with code since high
                        school and haven't been able to stop since.</p>
                    <p>I'm looking for a role where I can contribute to meaningful projects, work with people who care
                        about the craft, and continue to push my limits as a developer.</p>
                </div>
                <div class="about-details">
                    <div class="detail-item">
                        <span class="detail-label">Location</span>
                        <span class="detail-value">Ontario, Canada</span>
                    </div>
                    <div class="detail-item">
                        <span class="detail-label">Languages</span>
                        <span class="detail-value">English, French</span>
                    </div>
                    <div class="detail-item">
                        <span class="detail-label">Availability</span>
                        <span class="detail-value availability">Open to opportunities</span>
                    </div>
                    <div class="detail-item">
                        <span class="detail-label">Focus</span>
                        <span class="detail-value">Web Development</span>
                    </div>
                </div>
            </div>
        </section>

        <!-- Education -->
        <section class="work-section" id="education">
            <div class="section-label">Education</div>
            <div class="edu-list">
                {education.map(e => (
                        <div class="edu-card">
                            <div class="edu-left">
                                <div class="edu-top">
                                    <img src={e.logo} alt={e.school} class="edu-logo"/>
                                    <div>
                                        <div class="edu-school">{e.school}</div>
                                        <div class="edu-degree">{e.degree}</div>
                                    </div>
                                </div>
                            </div>
                            <div class="edu-right">
                                <div class="edu-year">{e.year}</div>
                                {e.gpa &&
                                        <div class="edu-gpa">GPA <span>{e.gpa}</span></div>}
                            </div>
                        </div>
                ))}
            </div>
        </section>

        <!-- Experience -->
        <section class="work-section" id="experience">
            <div class="section-label">Experience</div>
            <div class="exp-timeline">
                {experience.map(e => (
                        <div class="exp-entry">
                            <div class="timeline-dot"></div>
                            <div class="exp-card">
                                <div class="exp-header">
                                    <div class="exp-left">
                                        <div class="exp-role">{e.role}</div>
                                        <div class="exp-company">{e.company}</div>
                                    </div>
                                    <div class="exp-period">{e.period}</div>
                                </div>
                                <ul class="exp-bullets">
                                    {e.bullets.map(b =>
                                            <li>{b}</li>)}
                                </ul>
                            </div>
                        </div>
                ))}
            </div>
        </section>

        <!-- Stack -->
        <section class="work-section" id="stack">
            <div class="section-label">Tech Stack</div>
            <div class="stack-categories">
                {stack.map(group => (
                        <div class="stack-group">
                            <div class="stack-category-label">{group.category}</div>
                            <div class="stack-list">
                                {group.items.map(s => (
                                        <div class="stack-item">
                                            <img src={s.icon} alt={s.name}
                                                 class={`stack-icon${s.invert ? " stack-icon--invert" : ""}`}/>
                                            <span class="stack-name">{s.name}</span>
                                        </div>
                                ))}
                            </div>
                        </div>
                ))}
            </div>
        </section>

        <!-- Projects -->
        <section class="work-section" id="projects">
            <div class="section-label">Projects</div>
            <div class="projects-list">
                {projects.map(p => (
                        <div class="project-card">
                            <div class="project-header">
                                <div class="project-header-left">
                                    <img src={p.icon} alt={p.name} class="project-icon"/>
                                    <h3 class="project-name">{p.name}</h3>
                                </div>
                                <a href={p.url} target="_blank" rel="noopener noreferrer" class="project-github">
                                    GitHub
                                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24"
                                         fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"
                                         stroke-linejoin="round">
                                        <path d="M7 7h10v10"/>
                                        <path d="M7 17 17 7"/>
                                    </svg>
                                </a>
                            </div>
                            <p class="project-desc">{p.desc}</p>
                            <ul class="project-highlights">
                                {p.highlights.map(h =>
                                        <li>{h}</li>)}
                            </ul>
                            <div class="project-tags">
                                {p.tags.map(tag => <span class="tag">{tag}</span>)}
                            </div>
                        </div>
                ))}
            </div>
            <a href="/projects" class="all-projects-link">
                View all projects
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none"
                     stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M5 12h14"/>
                    <path d="m12 5 7 7-7 7"/>
                </svg>
            </a>
        </section>

    </div>

</Layout>

<style>
    /* Hero */
    .hero {
        min-height: 60vh;
        display: flex;
        align-items: center;
        padding: 8rem 2rem 5rem;
    }

    .hero-inner {
        max-width: 720px;
        margin: 0 auto;
        width: 100%;
    }

    .hero-label {
        font-size: 0.8rem;
        font-weight: 700;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        color: var(--blue);
        margin-bottom: 1rem;
    }

    .hero-name {
        display: inline-block;
        font-family: "Outfit", system-ui, sans-serif;
        font-size: clamp(3rem, 7vw, 5rem);
        font-weight: 700;
        line-height: 1.05;
        letter-spacing: -0.02em;
        background: linear-gradient(90deg, var(--blue), var(--purple));
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
        padding-bottom: 0.2em;
        filter: drop-shadow(2px 3px 6px rgba(0, 0, 0, 0.8));
        margin-bottom: 1.25rem;
    }

    .hero-tagline {
        font-size: 1.05rem;
        color: var(--text-muted);
        line-height: 1.75;
        max-width: 520px;
        margin-bottom: 2rem;
    }

    .hero-actions {
        display: flex;
        gap: 0.75rem;
        flex-wrap: wrap;
    }

    .btn-primary {
        padding: 0.65rem 1.5rem;
        border-radius: 8px;
        font-size: 0.85rem;
        font-weight: 600;
        text-decoration: none;
        background: linear-gradient(90deg, var(--blue), var(--purple));
        color: #fff;
        transition: opacity 0.2s;
    }

    .btn-primary:hover {
        opacity: 0.85;
    }

    .btn-secondary {
        padding: 0.65rem 1.5rem;
        border-radius: 8px;
        font-size: 0.85rem;
        font-weight: 500;
        text-decoration: none;
        border: 1px solid var(--border-mid);
        color: var(--text-muted);
        transition: border-color 0.2s, color 0.2s;
    }

    .btn-secondary:hover {
        border-color: var(--border-bright);
        color: var(--text);
    }

    /* Section nav */
    .section-nav {
        position: sticky;
        top: 4rem;
        z-index: 90;
        background: rgba(5, 8, 18, 0.8);
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
        border-bottom: 1px solid var(--border);
    }

    .section-nav::before {
        content: "";
        position: absolute;
        left: 0;
        right: 0;
        bottom: 100%;
        height: 3rem;
        background: linear-gradient(to bottom, transparent, rgba(5, 8, 18, 0.8));
        pointer-events: none;
    }

    .section-nav-inner {
        max-width: 720px;
        margin: 0 auto;
        padding: 0 2rem;
        display: flex;
        gap: 0;
    }

    .snav-link {
        padding: 0.75rem 1rem;
        font-size: 1rem;
        font-weight: 500;
        color: var(--text-dimmer);
        text-decoration: none;
        border-bottom: 2px solid transparent;
        transition: color 0.2s, border-color 0.2s;
        white-space: nowrap;
    }

    .snav-link:hover {
        color: var(--text-muted);
    }

    .snav-link.active {
        color: var(--text);
        border-bottom-color: var(--blue);
    }

    /* Body */
    .work-body {
        max-width: 720px;
        margin: 0 auto;
        padding: 0 2rem 8rem;
    }

    .work-section {
        padding: 4rem 0;
        border-bottom: 1px solid rgba(255, 255, 255, 0.05);
        scroll-margin-top: 100px;
    }

    .work-section:last-child {
        border-bottom: none;
    }

    .section-label {
        font-size: 1.25rem;
        font-weight: 700;
        letter-spacing: 0.02em;
        color: var(--text-dim);
        margin-bottom: 2rem;
    }

    /* About */
    .about-grid {
        display: grid;
        grid-template-columns: 1fr 200px;
        gap: 3rem;
        align-items: start;
    }

    @media (max-width: 600px) {
        .about-grid {
            grid-template-columns: 1fr;
        }
    }

    .about-text {
        display: flex;
        flex-direction: column;
        gap: 1rem;
    }

    .about-text p {
        font-size: 0.95rem;
        color: var(--text-muted);
        line-height: 1.75;
    }

    .about-details {
        display: flex;
        flex-direction: column;
        gap: 1rem;
        padding-top: 0.25rem;
    }

    .detail-item {
        display: flex;
        flex-direction: column;
        gap: 0.15rem;
    }

    .detail-label {
        font-size: 0.7rem;
        font-weight: 700;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        color: var(--text-dimmest);
    }

    .detail-value {
        font-size: 0.8rem;
        color: var(--text-muted);
    }

    .availability {
        color: #22c55e;
    }

    /* Education */
    .edu-list {
        display: flex;
        flex-direction: column;
        gap: 1rem;
    }

    .edu-card {
        display: flex;
        justify-content: space-between;
        align-items: start;
        gap: 2rem;
        padding: 1.25rem 1.5rem;
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: 12px;
    }

    .edu-top {
        display: flex;
        align-items: center;
        gap: 0.9rem;
    }

    .edu-logo {
        width: 40px;
        height: 40px;
        object-fit: contain;
        border-radius: 6px;
        flex-shrink: 0;
    }

    .edu-school {
        font-size: 0.95rem;
        font-weight: 600;
        color: var(--text);
        margin-bottom: 0.2rem;
    }

    .edu-degree {
        font-size: 0.85rem;
        color: var(--text-dim);
    }

    .edu-right {
        text-align: right;
        flex-shrink: 0;
    }

    .edu-year {
        font-size: 0.8rem;
        color: var(--text-dimmer);
    }

    .edu-gpa {
        font-size: 0.8rem;
        color: var(--text-dimmer);
        margin-top: 0.3rem;
    }

    .edu-gpa span {
        color: var(--text-muted);
    }

    /* Experience */
    .exp-timeline {
        position: relative;
        padding-left: 28px;
    }

    .exp-timeline::before {
        content: "";
        position: absolute;
        left: 5px;
        top: 1.5rem;
        bottom: 1.5rem;
        width: 1px;
        background: rgba(255, 255, 255, 0.08);
    }

    .exp-entry {
        position: relative;
        margin-bottom: 1rem;
    }

    .exp-entry:last-child {
        margin-bottom: 0;
    }

    .timeline-dot {
        position: absolute;
        left: -29px;
        top: 1.35rem;
        width: 11px;
        height: 11px;
        border-radius: 50%;
        background: #050812;
        border: 2px solid var(--blue);
        box-shadow: 0 0 8px rgba(0, 148, 255, 0.4);
        z-index: 1;
    }

    .exp-card {
        padding: 1.25rem 1.5rem;
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: 12px;
    }

    .exp-header {
        display: flex;
        justify-content: space-between;
        align-items: start;
        gap: 2rem;
        margin-bottom: 1rem;
    }

    .exp-role {
        font-size: 0.95rem;
        font-weight: 600;
        color: var(--text);
        margin-bottom: 0.2rem;
    }

    .exp-company {
        font-size: 0.9rem;
        color: var(--text-dim);
    }

    .exp-period {
        font-size: 0.8rem;
        color: var(--text-dimmer);
        flex-shrink: 0;
    }

    ul {
        list-style-type: disc;
    }

    .exp-bullets {
        display: flex;
        flex-direction: column;
        gap: 0.4rem;
        padding-left: 1rem;
        margin: 0;
    }

    .exp-bullets li {
        font-size: 0.85rem;
        color: var(--text-dim);
        line-height: 1.6;
    }

    /* Stack */
    .stack-categories {
        display: flex;
        flex-direction: column;
        gap: 1.75rem;
    }

    .stack-category-label {
        font-size: 1rem;
        font-weight: 700;
        color: var(--text-dimmest);
        margin-bottom: 0.6rem;
    }

    .stack-list {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 0.4rem;
    }

    @media (max-width: 500px) {
        .stack-list {
            grid-template-columns: repeat(2, 1fr);
        }
    }

    .stack-item {
        display: flex;
        align-items: center;
        gap: 0.6rem;
        padding: 0.55rem 0.75rem;
        background: var(--surface);
        border: 1px solid rgba(255, 255, 255, 0.06);
        border-radius: 8px;
    }

    .stack-icon {
        width: 20px;
        height: 20px;
        flex-shrink: 0;
    }

    .stack-icon--invert {
        filter: invert(1);
    }

    .stack-name {
        font-size: 0.85rem;
        color: var(--text-muted);
        white-space: nowrap;
    }

    /* Projects */
    .projects-list {
        display: flex;
        flex-direction: column;
        gap: 1rem;
    }

    .project-card {
        padding: 1.5rem 1.75rem;
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: 12px;
        transition: border-color 0.25s, background 0.25s, transform 0.25s, box-shadow 0.25s;
    }

    .project-card:hover {
        border-color: rgba(0, 148, 255, 0.3);
        background: var(--surface-hover);
        transform: translateY(-2px);
        box-shadow: 0 8px 32px rgba(0, 148, 255, 0.08);
    }

    .project-card:hover .project-name {
        color: var(--blue);
    }

    .project-card:hover .project-icon {
        transform: scale(1.08);
    }

    .project-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
        margin-bottom: 0.85rem;
    }

    .project-header-left {
        display: flex;
        align-items: center;
        gap: 0.6rem;
    }

    .project-icon {
        width: 28px;
        height: 28px;
        object-fit: contain;
        border-radius: 6px;
        flex-shrink: 0;
        transition: transform 0.25s;
    }

    .project-name {
        font-family: "Outfit", system-ui, sans-serif;
        font-size: 1.1rem;
        font-weight: 600;
        color: var(--text);
        transition: color 0.25s;
    }

    .project-github {
        display: flex;
        align-items: center;
        gap: 0.3rem;
        font-size: 0.9rem;
        font-weight: 500;
        color: var(--text-dimmer);
        text-decoration: none;
        transition: color 0.2s;
        flex-shrink: 0;
    }

    .project-github:hover {
        color: var(--blue);
    }

    .project-desc {
        font-size: 0.9rem;
        color: var(--text-dim);
        line-height: 1.7;
        margin-bottom: 1rem;
    }

    .project-highlights {
        display: flex;
        flex-direction: column;
        gap: 0.35rem;
        padding-left: 1rem;
        margin: 0 0 1rem;
    }

    .project-highlights li {
        font-size: 0.9rem;
        color: var(--text-dimmer);
        line-height: 1.5;
    }

    .project-tags {
        display: flex;
        flex-wrap: wrap;
        gap: 0.35rem;
    }

    .tag {
        font-size: 0.75rem;
        color: var(--blue);
        background: rgba(0, 148, 255, 0.08);
        border: 1px solid rgba(0, 148, 255, 0.2);
        border-radius: 4px;
        padding: 0.15rem 0.5rem;
    }

    .all-projects-link {
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
        margin-top: 1.5rem;
        font-size: 0.9rem;
        font-weight: 500;
        color: var(--text-dim);
        text-decoration: none;
        transition: color 0.2s;
    }

    .all-projects-link:hover {
        color: var(--text);
    }
</style>

<script>
    // @ts-nocheck

    // Section nav active state
    const sections = document.querySelectorAll(".work-section");
    const navLinks = document.querySelectorAll(".snav-link");
    const OFFSET = 110; // main nav + section nav combined height

    function updateNav() {
        let current = sections[0].id;
        sections.forEach(section => {
            if (section.offsetTop - OFFSET <= window.scrollY) {
                current = section.id;
            }
        });
        navLinks.forEach(link => {
            link.classList.toggle("active", link.dataset.section === current);
        });
    }

    window.addEventListener("scroll", updateNav, { passive: true });
    updateNav();
</script>
