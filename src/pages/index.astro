        font-family: "Outfit", system-ui, sans-serif;
        font-size: 0.95rem;
        font-weight: 700;
        color: var(--blue);
    }

    .sc-stat-name {
        font-size: 0.9rem;
        color: var(--text-dimmer);
    }

    .sc-stat-sep {
        color: var(--text-dimmest);
        font-size: 0.75rem;
    }

