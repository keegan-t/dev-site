---
const year = new Date().getFullYear();

const links = [
    { label: "GitHub", href: "https://github.com/keegan-t" },
    { label: "YouTube", href: "https://www.youtube.com/@Keegan-T" },
    { label: "Last.fm", href: "https://www.last.fm/user/KeeganTZ" },
];
---

<footer class="site-footer">
    <div class="footer-inner">
        <p class="footer-copy">© {year} Keegan Tournay</p>
        <div class="footer-links">
            {links.map(link => (
                    <a href={link.href} class="footer-link" target="_blank" rel="noopener noreferrer">
                        {link.label}
                    </a>
            ))}
        </div>
    </div>
</footer>

<style>
    .site-footer {
        position: relative;
        z-index: 10;
        border-top: 1px solid var(--border);
        margin-top: 6rem;
    }

    .footer-inner {
        max-width: 80rem;
        margin: 0 auto;
        padding: 2rem 1.5rem;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
    }

    @media (min-width: 640px) {
        .footer-inner {
            flex-direction: row;
        }
    }

    .footer-copy {
        font-size: 0.9rem;
        color: var(--text-dim);
    }

    .footer-links {
        display: flex;
        align-items: center;
        gap: 1.5rem;
    }

    .footer-link {
        font-size: 0.9rem;
        color: var(--text-dim);
        text-decoration: none;
        transition: color 0.2s;
    }

    .footer-link:hover {
        color: #fff;
    }
</style>
