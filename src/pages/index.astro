    }

    /* Scroll reveal */
    .reveal {
        opacity: 0;
        transform: translateY(32px);
        transition: opacity 0.7s ease, transform 0.7s ease;
    }

    .reveal.visible {
        opacity: 1;
        transform: translateY(0);
    }

    .delay-1 {
        transition-delay: 0.15s;
    }
</style>

<script>
    // @ts-nocheck

    // Scroll reveal
    const observer = new IntersectionObserver(
        (entries) => entries.forEach(e => {
            if (e.isIntersecting) {
                e.target.querySelectorAll(".reveal").forEach(el => el.classList.add("visible"));
            }
        }),
        { rootMargin: "0px 0px -25% 0px" }
    );
    document.querySelectorAll(".int-section").forEach(el => observer.observe(el));

    // Solve detail card
    const solveCard = document.getElementById("solve-card");

    document.querySelectorAll(".solve-row[data-solve]").forEach(row => {
        row.addEventListener("mouseenter", () => {
            const solve = JSON.parse(row.dataset.solve);

            solveCard.querySelector(".sc-scramble").textContent = solve.scramble;

            const recoEl = solveCard.querySelector(".sc-reco");
            recoEl.innerHTML = "";
            solve.reconstruction.split("\n").forEach(line => {
                const sep = line.indexOf("//");
                const moves = sep >= 0 ? line.slice(0, sep).trim() : line.trim();
                const comment = sep >= 0 ? line.slice(sep + 2).trim() : "";
                const div = document.createElement("div");
                div.className = "sc-reco-line";
                div.innerHTML = `<span class="sc-moves">${moves}</span><span class="sc-comment">${comment ? " // " + comment : ""}</span>`;
                recoEl.appendChild(div);
            });

            solveCard.querySelector(".sc-stat-moves").textContent = solve.moves;
            solveCard.querySelector(".sc-stat-tps").textContent = Number(solve.tps).toFixed(2);
            const rotEl = solveCard.querySelector(".sc-stat-rotations");
            rotEl.textContent = solve.rotations;
            rotEl.nextElementSibling.textContent = solve.rotations === 1 ? "rotation" : "rotations";

            const rect = row.closest(".widget-box").getBoundingClientRect();
            const cardW = 320;
            let left = rect.right + 16;
            if (left + cardW > window.innerWidth - 16) left = rect.left - cardW - 16;
            left = Math.max(16, left);
            const top = Math.max(16, Math.min(window.innerHeight - 260, rect.top + rect.height / 2 - 120));
            solveCard.style.left = left + "px";
            solveCard.style.top = top + "px";
            solveCard.classList.add("visible");
        });

        row.addEventListener("mouseleave", () => solveCard.classList.remove("visible"));
    });

    // Audio clip hover
    let activeAudio = null;
    let audioEnabled = false;

    const audioToggle = document.getElementById("audio-toggle");
    audioToggle.addEventListener("click", () => {
        audioEnabled = !audioEnabled;
        audioToggle.classList.toggle("enabled", audioEnabled);
        if (!audioEnabled && activeAudio) {
            activeAudio.pause();
            activeAudio.currentTime = 0;
            activeAudio = null;
            document.querySelectorAll(".track-row.playing").forEach(r => r.classList.remove("playing"));
        }
    });

    document.querySelectorAll(".track-row[data-clip]").forEach(row => {
        const clip = row.dataset.clip;
        if (!clip) return;

        row.addEventListener("mouseenter", () => {
            if (!audioEnabled) return;
            document.querySelectorAll(".track-row.playing").forEach(r => r.classList.remove("playing"));
            if (activeAudio) {
                activeAudio.pause();
                activeAudio.currentTime = 0;
            }
            activeAudio = new Audio(clip);
            activeAudio.volume = 0.1;
            activeAudio.play().catch(() => {
            });
            row.classList.add("playing");
        });

        row.addEventListener("mouseleave", () => {
            row.classList.remove("playing");
            if (activeAudio) {
                activeAudio.pause();
                activeAudio.currentTime = 0;
                activeAudio = null;
            }
        });
    });
</script>
