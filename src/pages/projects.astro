---
import Layout from "../layouts/Layout.astro";
import { readFileSync } from "fs";
import { join } from "path";

const projects = JSON.parse(readFileSync(join(process.cwd(), "src/data/projects.json"), "utf8"));
---

<Layout title="Projects">

    <div class="page-header">
        <div class="page-header-inner">
            <h1 class="page-title">Projects</h1>
            <svg class="title-ornament" viewBox="0 0 460 28" width="460" height="28" xmlns="http://www.w3.org/2000/svg">
                <!-- Constellation line -->
                <line x1="12" y1="14" x2="448" y2="14" stroke="rgba(255,255,255,0.2)" stroke-width="1"/>
                <!-- Left star glow layers -->
                <circle cx="12" cy="14" r="10" fill="white" opacity="0.04"/>
                <circle cx="12" cy="14" r="5" fill="white" opacity="0.08"/>
                <circle cx="12" cy="14" r="2" fill="white" opacity="0.9"/>
                <!-- Left secondary star -->
                <circle cx="121" cy="14" r="10" fill="white" opacity="0.04"/>
                <circle cx="121" cy="14" r="5" fill="white" opacity="0.08"/>
                <circle cx="121" cy="14" r="2" fill="white" opacity="0.9"/>
                <!-- Center diamond -->
                <circle cx="230" cy="14" r="10" fill="white" opacity="0.05"/>
                <circle cx="230" cy="14" r="5" fill="white" opacity="0.1"/>
                <polygon points="230,9 235,14 230,19 225,14" fill="white" opacity="0.9"/>
                <!-- Right secondary star -->
                <circle cx="339" cy="14" r="10" fill="white" opacity="0.04"/>
                <circle cx="339" cy="14" r="5" fill="white" opacity="0.08"/>
                <circle cx="339" cy="14" r="2" fill="white" opacity="0.9"/>
                <!-- Right star glow layers -->
                <circle cx="448" cy="14" r="10" fill="white" opacity="0.04"/>
                <circle cx="448" cy="14" r="5" fill="white" opacity="0.08"/>
                <circle cx="448" cy="14" r="2" fill="white" opacity="0.9"/>
            </svg>
            <p class="page-sub">Things I've built!</p>
        </div>
    </div>

    <div class="projects-grid-wrap">
        <div class="projects-grid">
            {projects.map(p => (
                    <div class="pcard">
                        <div class="pcard-thumb-wrap">
                            <img src={p.thumbnail} alt={p.name} class="pcard-thumb" loading="lazy"/>
                        </div>
                        <div class="pcard-body">
                            <div class="pcard-title-row">
                                {p.icon && <img src={p.icon} alt={p.name} class="pcard-icon"/>}
                                <h2 class="pcard-name">{p.name}</h2>
                            </div>
                            <p class="pcard-desc">{p.desc}</p>
                            <div class="pcard-footer">
                                <div class="pcard-tags">
                                    {p.tags.map(tag => <span class="tag">{tag}</span>)}
                                </div>
                                <div class="pcard-links">
                                    <a href={p.url} target="_blank" rel="noopener noreferrer" class="pcard-link">
                                        <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13"
                                             viewBox="0 0 24 24" fill="currentColor">
                                            <path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0 1 12 6.844a9.59 9.59 0 0 1 2.504.337c1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.02 10.02 0 0 0 22 12.017C22 6.484 17.522 2 12 2z"/>
                                        </svg>
                                        GitHub
                                    </a>
                                    {p.live && (
                                            <a href={p.live} target="_blank" rel="noopener noreferrer"
                                               class="pcard-link pcard-link--live">
                                                <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13"
                                                     viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                                     stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                                    <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/>
                                                    <polyline points="15 3 21 3 21 9"/>
                                                    <line x1="10" y1="14" x2="21" y2="3"/>
                                                </svg>
                                                Live
                                            </a>
                                    )}
                                    {p.discord && (
                                            <a href={p.discord} target="_blank" rel="noopener noreferrer"
                                               class="pcard-link pcard-link--discord">
                                                <svg width="13" height="13" viewBox="0 -28.5 256 256"
                                                     xmlns="http://www.w3.org/2000/svg" fill="currentColor">
                                                    <path d="M216.856339,16.5966031 C200.285002,8.84328665 182.566144,3.2084988 164.041564,0 C161.766523,4.11318106 159.108624,9.64549908 157.276099,14.0464379 C137.583995,11.0849896 118.072967,11.0849896 98.7430163,14.0464379 C96.9108417,9.64549908 94.1925838,4.11318106 91.8971895,0 C73.3526068,3.2084988 55.6133949,8.86399117 39.0420583,16.6376612 C5.61752293,67.146514 -3.4433191,116.400813 1.08711069,164.955721 C23.2560196,181.510915 44.7403634,191.567697 65.8621325,198.148576 C71.0772151,190.971126 75.7283628,183.341335 79.7352139,175.300261 C72.104019,172.400575 64.7949724,168.822202 57.8887866,164.667963 C59.7209612,163.310589 61.5131304,161.891452 63.2445898,160.431257 C105.36741,180.133187 151.134928,180.133187 192.754523,160.431257 C194.506336,161.891452 196.298154,163.310589 198.110326,164.667963 C191.183787,168.842556 183.854737,172.420929 176.223542,175.320965 C180.230393,183.341335 184.861538,190.991831 190.096624,198.16893 C211.238746,191.588051 232.743023,181.531619 254.911949,164.955721 C260.227747,108.668201 245.831087,59.8662432 216.856339,16.5966031 Z M85.4738752,135.09489 C72.8290281,135.09489 62.4592217,123.290155 62.4592217,108.914901 C62.4592217,94.5396472 72.607595,82.7145587 85.4738752,82.7145587 C98.3405064,82.7145587 108.709962,94.5189427 108.488529,108.914901 C108.508531,123.290155 98.3405064,135.09489 85.4738752,135.09489 Z M170.525237,135.09489 C157.88039,135.09489 147.510584,123.290155 147.510584,108.914901 C147.510584,94.5396472 157.658606,82.7145587 170.525237,82.7145587 C183.391518,82.7145587 193.761324,94.5189427 193.539891,108.914901 C193.539891,123.290155 183.391518,135.09489 170.525237,135.09489 Z"/>
                                                </svg>
                                                Discord
                                            </a>
                                    )}
                                </div>
                            </div>
                        </div>
                    </div>
            ))}
        </div>
    </div>

</Layout>

<style>
    /* Page header */
    .page-header {
        padding: 8rem 2rem 3.5rem;
        text-align: center;
    }

    .page-header-inner {
        max-width: 600px;
        margin: 0 auto;
    }

    .page-title {
        display: inline-block;
        font-family: "Outfit", system-ui, sans-serif;
        font-size: clamp(3rem, 8vw, 4.5rem);
        font-weight: 700;
        line-height: 1.05;
        background: linear-gradient(90deg, var(--blue), var(--purple));
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
        padding-bottom: 0.2em;
        filter: drop-shadow(2px 3px 6px rgba(0, 0, 0, 0.8));
        margin-bottom: 0.75rem;
    }

    .title-ornament {
        display: block;
        margin: 0.5rem auto 1rem;
        max-width: 100%;
    }

    .page-sub {
        font-size: 1.1rem;
        color: var(--text-dimmer);
        font-weight: 700;
    }

    /* Grid */
    .projects-grid-wrap {
        padding: 0 2rem 8rem;
    }

    .projects-grid {
        max-width: 960px;
        margin: 0 auto;
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
        gap: 1rem;
    }

    /* Card */
    .pcard {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: 12px;
        overflow: hidden;
        display: flex;
        flex-direction: column;
        transition: border-color 0.25s, background 0.25s, transform 0.25s, box-shadow 0.25s;
    }

    .pcard:hover {
        border-color: rgba(0, 148, 255, 0.3);
        background: var(--surface-hover);
        transform: translateY(-3px);
        box-shadow: 0 10px 36px rgba(0, 148, 255, 0.08);
    }

    .pcard-thumb-wrap {
        width: 100%;
        aspect-ratio: 16 / 9;
        overflow: hidden;
        display: flex;
        align-items: center;
        justify-content: center;
        background: #0a0e1a;
        transition: background 0.3s;
    }

    .pcard-thumb {
        max-width: 100%;
        max-height: 100%;
        object-fit: contain;
        border-radius: 4px;
    }

    .pcard-body {
        display: flex;
        flex-direction: column;
        flex: 1;
        padding: 1.1rem 1.25rem;
        gap: 0.6rem;
    }

    .pcard-title-row {
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }

    .pcard-icon {
        width: 22px;
        height: 22px;
        object-fit: contain;
        border-radius: 5px;
        flex-shrink: 0;
    }

    .pcard-name {
        font-family: "Outfit", system-ui, sans-serif;
        font-size: 0.98rem;
        font-weight: 600;
        color: var(--text);
        transition: color 0.25s;
    }

    .pcard:hover .pcard-name {
        color: var(--blue);
    }

    .pcard-desc {
        font-size: 0.82rem;
        color: var(--text-dim);
        line-height: 1.65;
    }

    .pcard-footer {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 0.5rem;
        margin-top: auto;
        padding-top: 0.5rem;
    }

    .pcard-tags {
        display: flex;
        flex-wrap: wrap;
        gap: 0.3rem;
    }

    .tag {
        font-size: 0.65rem;
        color: var(--blue);
        background: rgba(0, 148, 255, 0.08);
        border: 1px solid rgba(0, 148, 255, 0.2);
        border-radius: 4px;
        padding: 0.12rem 0.45rem;
    }

    .pcard-links {
        margin-top: auto;
        display: flex;
        gap: 0.5rem;
        flex-shrink: 0;
    }

    .pcard-link {
        display: inline-flex;
        align-items: center;
        gap: 0.3rem;
        font-size: 0.72rem;
        font-weight: 500;
        color: var(--text-dimmer);
        text-decoration: none;
        transition: color 0.2s;
    }

    .pcard-link:hover {
        color: var(--text-muted);
    }

    .pcard-link--live {
        color: #22c55e;
    }

    .pcard-link--live:hover {
        color: #4ade80;
    }

    .pcard-link--discord {
        color: #5865F2;
    }

    .pcard-link--discord:hover {
        color: #7983f5;
    }
</style>

<script>
    // @ts-nocheck

    // Thumbnail background color sampling
    function sampleColor(img) {
        const canvas = document.createElement("canvas");
        canvas.width = img.naturalWidth;
        canvas.height = img.naturalHeight;
        const ctx = canvas.getContext("2d");
        ctx.drawImage(img, 0, 0);
        const data = ctx.getImageData(0, 0, canvas.width, canvas.height).data;
        let r = 0, g = 0, b = 0, count = 0;
        for (let i = 0; i < data.length; i += 4 * 8) { // sample every 8th pixel
            r += data[i];
            g += data[i + 1];
            b += data[i + 2];
            count++;
        }
        const factor = 0.55; // darken so the image stays the focal point
        return `rgb(${Math.round(r / count * factor)}, ${Math.round(g / count * factor)}, ${Math.round(b / count * factor)})`;
    }

    document.querySelectorAll(".pcard-thumb-wrap").forEach(wrap => {
        const img = wrap.querySelector(".pcard-thumb");
        if (!img) return;
        const apply = () => {
            wrap.style.background = sampleColor(img);
        };
        if (img.complete && img.naturalWidth) apply();
        else img.addEventListener("load", apply);
    });
</script>
