---
import NavBar from "../components/NavBar.astro";
import Footer from "../components/Footer.astro";
import Starfield from "../components/Starfield.astro";
import "../styles/global.css";
import "@fontsource-variable/outfit";
import "@fontsource-variable/inter";
import "@fontsource-variable/inter/wght-italic.css";
import outfitUrl from "@fontsource-variable/outfit/files/outfit-latin-wght-normal.woff2?url";
import interUrl from "@fontsource-variable/inter/files/inter-latin-wght-normal.woff2?url";
import interItalicUrl from "@fontsource-variable/inter/files/inter-latin-wght-italic.woff2?url";

interface Props {
    title: string;
    description?: string;
}

const {
    title,
    description = "Keegan Tournay - Software Developer",
} = Astro.props;

const pageTitle = title === "Home" ? "Keegan Tournay" : `${title} | Keegan Tournay`;
---

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <meta name="description" content={description}/>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg"/>
    <link rel="preload" as="font" type="font/woff2" href={outfitUrl} crossorigin/>
    <link rel="preload" as="font" type="font/woff2" href={interUrl} crossorigin/>
    <link rel="preload" as="font" type="font/woff2" href={interItalicUrl} crossorigin/>
    <title>{pageTitle}</title>
</head>
<body>
<Starfield/>
<NavBar/>
<main>
    <slot/>
</main>
<Footer/>
</body>
</html>
